generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String?  @unique
  displayName String?
  username  String?  @unique
  referralCode String? @unique
  referredById String?
  fullName  String?
  avatarUrl String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile  Profile?
  wallet   CreditWallet?
  jobs     GenerationJob[]
  assets   Asset[]
  posts    PublishedPost[]
  likes    Like[]
  comments Comment[]

  followers Follow[] @relation("UserFollowers")
  following Follow[] @relation("UserFollowing")
  drafts    PromptDraft[]
  assetLikes AssetLike[]
  assetSaves AssetSave[]
  assetComments AssetComment[]
  notifications Notification[] @relation("UserNotifications")
  actorNotifications Notification[] @relation("ActorNotifications")
  creditLedger CreditLedger[]
  payments    Payment[]
  videoProjects VideoProject[]
  characters Character[]
  subscription Subscription?
  subscriptionRenewals SubscriptionRenewal[]
  subscriptionCancelFeedback SubscriptionCancelFeedback[]
  curatedTemplates Template[] @relation("TemplateAdmin")
  referredBy User? @relation("UserReferral", fields: [referredById], references: [id])
  referrals  User[] @relation("UserReferral")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  website   String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditWallet {
  id           String              @id @default(cuid())
  userId       String              @unique
  balance      Int                 @default(0)
  reservedBalance Int              @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions CreditTransaction[]

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id          String   @id @default(cuid())
  walletId    String
  userId      String
  type        String
  amount      Int
  description String?
  reference   String?
  createdAt   DateTime @default(now())

  wallet      CreditWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model GenerationJob {
  id                String   @id @default(cuid())
  userId            String
  modelId           String?
  type              String
  status            String
  providerName      String?
  fallbackProviderName String?
  providerJobId     String?
  failureReason     String?
  failoverReason    String?
  failoverAt        DateTime?
  refundedAt        DateTime?
  storageProvider   String?
  storageUrl        String?
  storagePublicId   String?
  storageStatus     String?
  storageReason     String?
  queueAttempts     Int      @default(0)
  lastCheckedAt     DateTime?
  queueLastError    String?
  prompt            String?
  negativePrompt    String?
  outputUrl         String?
  creditsUsed       Int      @default(0)

  // image-oriented fields
  style             String?
  aspectRatio       String?
  qualityMode       String?
  promptBoost       Boolean  @default(true)
  seed              Int?
  steps             Int?
  guidance          Float?

  // video-oriented fields
  duration          Int?
  motionIntensity   String?
  cameraMove        String?
  styleStrength     String?
  motionGuidance    Int?
  shotType          String?
  fps               Int?
  sourceImageUrl    String?
  sourceAssetId     String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  completedAt       DateTime?

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset             Asset?
  character         Character?
  creditLedger      CreditLedger[]
  templates         Template[]
}

model Character {
  id              String   @id @default(cuid())
  userId          String
  generationJobId String?  @unique
  name            String
  description     String?
  backgroundStory String?
  mode            String
  status          String   @default("processing")
  modelId         String?
  prompt          String?
  sourceImageUrl  String?
  imageUrl        String?
  style           String?
  vibe            String?
  gender          String?
  ethnicity       String?
  ageRange        String?
  count           Int      @default(1)
  creditsUsed     Int      @default(0)
  failureReason   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob   GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  reference   String   @unique
  provider    String
  status      String
  amount      Int
  currency    String
  packKey     String?
  credits     Int      @default(0)
  rawPayload  Json?
  creditedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String   @unique
  plan             String
  status           String
  creditsPerMonth  Int
  currentPeriodEnd DateTime
  paystackSubscriptionCode String?
  paystackEmailToken       String?
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  renewals         SubscriptionRenewal[]
  cancelFeedback   SubscriptionCancelFeedback[]
}

model SubscriptionRenewal {
  id              String   @id @default(cuid())
  userId          String
  subscriptionId  String?
  reference       String   @unique
  plan            String
  creditsGranted  Int
  rawPayload      Json?
  createdAt       DateTime @default(now())

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
}

model SubscriptionCancelFeedback {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String?
  reason         String
  note           String?
  createdAt      DateTime @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
}

model AppRuntimeConfig {
  id             String   @id @default("default")
  backgroundMode String   @default("inline")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PaymentAuditLog {
  id         String   @id @default(cuid())
  reference  String?
  provider   String
  eventType  String
  status     String
  reason     String?
  rawPayload Json?
  createdAt  DateTime @default(now())
}

model PromptSafetyLog {
  id             String   @id @default(cuid())
  userId         String?
  prompt         String
  negativePrompt String?
  reason         String
  matchedTerm    String?
  createdAt      DateTime @default(now())
}

model CreditLedger {
  id              String         @id @default(cuid())
  userId          String
  generationJobId String?
  sceneId         String?
  videoProjectId  String?
  adminId         String?
  type            String
  amount          Int
  description     String?
  reference       String?
  operationKey    String?        @unique
  metadata        Json?
  createdAt       DateTime       @default(now())

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob   GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
}

model Asset {
  id              String   @id @default(cuid())
  userId          String
  generationJobId String?  @unique
  type            String
  mediaType       String   @default("image")
  title           String?
  prompt          String?
  fileUrl         String
  thumbnailUrl    String?
  mimeType        String?
  width           Int?
  height          Int?
  isPublic        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
  post          PublishedPost?
  likes         AssetLike[]
  saves         AssetSave[]
  comments      AssetComment[]
  notifications Notification[]
  moderationLogs ModerationAuditLog[]
  templates      Template[]
}

model Template {
  id                    String   @id @default(cuid())
  title                 String
  type                  String
  category              String
  prompt                String
  negativePrompt        String?
  previewUrl            String
  thumbnailUrl          String?
  sourceAssetId         String?
  sourceGenerationJobId String?
  modelId               String?
  settings              Json?
  status                String   @default("draft")
  sortOrder             Int      @default(0)
  createdByAdminId      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  createdByAdmin      User?          @relation("TemplateAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  sourceAsset         Asset?         @relation(fields: [sourceAssetId], references: [id], onDelete: SetNull)
  sourceGenerationJob GenerationJob? @relation(fields: [sourceGenerationJobId], references: [id], onDelete: SetNull)

  @@index([status, sortOrder, createdAt])
  @@index([type, status])
  @@index([sourceAssetId])
  @@index([sourceGenerationJobId])
}

model ModerationAuditLog {
  id        String   @id @default(cuid())
  assetId   String
  adminId   String
  action    String
  note      String?
  createdAt DateTime @default(now())

  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetLike {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model AssetSave {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

model AssetComment {
  id        String   @id @default(cuid())
  assetId   String
  userId    String
  body      String
  createdAt DateTime @default(now())

  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublishedPost {
  id            String   @id @default(cuid())
  userId        String
  assetId       String   @unique
  caption       String?
  visibility    String   @default("public")
  viewsCount    Int      @default(0)
  likesCount    Int      @default(0)
  commentsCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset    Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  likes    Like[]
  comments Comment[]
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post PublishedPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  post PublishedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  actorId   String?
  type      String
  assetId   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?    @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: SetNull)
  asset     Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model PromptDraft {
  id              String   @id @default(cuid())
  userId          String
  modelId         String?
  type            String   @default("image")
  title           String
  prompt          String
  negativePrompt  String?

  style           String?
  aspectRatio     String?
  qualityMode     String?
  promptBoost     Boolean  @default(true)
  seed            Int?
  steps           Int?
  guidance        Float?

  duration        Int?
  motionIntensity String?
  cameraMove      String?
  resolution      String?
  draftMode       Boolean?
  saveAudio       Boolean?
  promptUpsampling Boolean?
  disableSafetyFilter Boolean?
  styleStrength   String?
  motionGuidance  Int?
  shotType        String?
  fps             Int?
  imageUrl        String?
  sourceAssetId   String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VideoProject {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  status      String   @default("draft")
  exportStatus String?
  exportAttemptId String?
  exportFailureReason String?
  exportUrl    String?
  exportedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes      VideoScene[]
  exports     VideoProjectExport[]
}

model VideoScene {
  id          String   @id @default(cuid())
  projectId   String
  order       Int
  title       String?
  prompt      String
  imageUrl    String?
  videoUrl    String?
  status      String   @default("draft")
  failureReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model VideoProjectExport {
  id            String   @id @default(cuid())
  projectId     String
  userId        String
  attemptId     String   @unique
  status        String
  exportUrl     String?
  failureReason String?
  creditsUsed   Int      @default(0)
  createdAt     DateTime @default(now())
  completedAt   DateTime?

  project       VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
